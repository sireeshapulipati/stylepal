# Backend
GEMINI_API_KEY=your_gemini_api_key

# Eval: OpenAI for Ragas evaluator (AIE9 style)
OPENAI_API_KEY=your_openai_api_key

# Advanced RAG: Cohere reranker (rag_advanced.py)
COHERE_API_KEY=your_cohere_api_key

# LangSmith tracing (optional - set LANGSMITH_TRACING=true to enable)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=stylepal
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
DATABASE_URL=sqlite:///./stylepal.db
STYLEPAL_DATA_DIR=backend/data

# Qdrant Cloud (vector DB for style knowledge)
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# Frontend (in frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
